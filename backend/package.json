{
  "name": "product-catalog-backend",
  "version": "1.0.0",
  "description": "Fastify backend with keyset (cursor) pagination over a large product catalog",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js",
    "explain": "node scripts/explain.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "vitest": "^2.0.5"
  }
}
