# ----------------------------------------------------------------------------
# Backend environment configuration
# Copy this file to `.env` and fill in your real values.
# ----------------------------------------------------------------------------

# Postgres / Supabase connection string.
# Supabase -> Project Settings -> Database -> Connection string (URI).
# For serverless/short-lived connections prefer the "Connection pooler" (port 6543)
# string. For the seeder (long bulk job) the direct connection (port 5432) is fine.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase (and most hosted Postgres) require TLS. Keep true in the cloud.
# Set to false only for a local Postgres without SSL.
PGSSL=true

# HTTP server
PORT=8080
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins for the frontend.
# Use * for local dev; in production set it to your Vercel URL.
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# How many rows the seeder inserts. The real task asks for ~200,000.
# The architecture scales to 1,000,000 — bump this to stress test.
SEED_COUNT=200000
SEED_BATCH_SIZE=10000

# Log level: info | debug | warn | error
LOG_LEVEL=info
NODE_ENV=development
